{
  "name": "@open-elements/nextjs-app-layer",
  "version": "0.1.0",
  "description": "Next.js foundation (auth, proxy, admin pages, login/forbidden, layout) for Open Elements applications",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenElementsLabs/nextjs-app-layer.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./server/next-auth-types": {
      "import": "./dist/server/next-auth-types.js",
      "types": "./dist/server/next-auth-types.d.ts"
    },
    "./layout": {
      "import": "./dist/layout/root-layout.js",
      "types": "./dist/layout/root-layout.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@open-elements/ui": "^0.7.0",
    "lucide-react": "^0.500.0",
    "next": "^15.3.0",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@open-elements/ui": "^0.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.500.0",
    "next": "^15.3.3",
    "next-auth": "5.0.0-beta.30",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
